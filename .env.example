HOST=0.0.0.0
PORT=8080
# Local run example:
# UPSTREAM_BASE_URL=http://localhost:3000
# Docker Compose example:
UPSTREAM_BASE_URL=http://one-api:3000
UPSTREAM_API_KEY=
INTERNAL_API_KEYS=internal-demo-key
ADMIN_API_KEYS=admin-demo-key
SESSION_STORE_DRIVER=memory
ALLOWED_MODELS=openai/gpt-3.5-turbo,qwen/qwen-vl-plus,deepseek/deepseek-r1
BLOCK_ON_INJECTION=false
OUTPUT_BLOCK_TERMS=
OUTPUT_BLOCK_MODE=replace
SESSION_TTL_SECONDS=1800
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
ENABLE_CONSOLE_AUDIT=true
AUDIT_LOG_PATH=logs/audit.jsonl
# Local Redis example:
# REDIS_URL=redis://127.0.0.1:6379/0
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=secumesh:session:
REDIS_PORT=6379
ONE_API_PORT=3000
TZ=Asia/Shanghai
ONE_API_SESSION_SECRET=secumesh_secret_change_me
